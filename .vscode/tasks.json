{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run C++ (root input/output)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "g++ -std=c++17 \"${file}\" -o \"${workspaceFolder}/program\" && \"${workspaceFolder}/program\" < \"${workspaceFolder}/input.txt\" > \"${workspaceFolder}/output.txt\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}